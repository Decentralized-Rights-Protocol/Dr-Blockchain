# DRP Docker Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# Blockchain Configuration
# ============================================
BLOCKCHAIN_NETWORK=drp-testnet
BLOCKCHAIN_RPC_URL=http://drp-node:8545

# ============================================
# Service Ports
# ============================================
RPC_PORT=8545
AI_PORT=8000
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# IPFS Configuration
# ============================================
IPFS_API_URL=http://ipfs:5001/api/v0
IPFS_GATEWAY_URL=http://ipfs:8080/ipfs

# ============================================
# AI Service Configuration
# ============================================
AI_API_KEY=your_ai_api_key_here
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO

# ============================================
# Security (Generate secure keys in production)
# ============================================
JWT_SECRET=change_this_to_a_secure_random_string
ENCRYPTION_KEY=change_this_to_a_secure_random_string

# ============================================
# Optional: Database Configuration
# ============================================
# SCYLLA_HOSTS=scylla-node1:9042,scylla-node2:9042,scylla-node3:9042
# SCYLLA_KEYSPACE=drp_proofs
# SCYLLA_REPLICATION_FACTOR=3

# ============================================
# Optional: Monitoring
# ============================================
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090
# GRAFANA_ENABLED=true
# GRAFANA_PORT=3000

# ============================================
# Optional: SSL/TLS (for HTTPS)
# ============================================
# SSL_DOMAIN=your-domain.com
# SSL_EMAIL=your-email@example.com



