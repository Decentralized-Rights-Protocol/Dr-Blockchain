# =============================================================================
# DRP Chain Environment Variables — Example
# =============================================================================
# Copy this file to chain/.env and fill in your values.
# NEVER commit chain/.env or any file with real key material.
#
# These variables are used by off-chain services (evidence submission,
# monitoring, API gateway) that interact with the DRP chain.
# The chain binary itself uses config files in ~/.drpd/config/.
# =============================================================================

# ── Chain identity ────────────────────────────────────────────────────────────
DRP_CHAIN_ID=drp-testnet-1
DRP_CHAIN_MONIKER=drp-validator-1

# ── RPC / API endpoints ───────────────────────────────────────────────────────
DRP_RPC_URL=http://localhost:26657
DRP_GRPC_URL=localhost:9090
DRP_REST_URL=http://localhost:1317

# ── IPFS integration ──────────────────────────────────────────────────────────
# The DRP evidence module stores only CIDs on-chain.
# Off-chain services use these endpoints to pin/fetch evidence bundles.
#
# For local development, run: docker run -p 4001:4001 -p 5001:5001 -p 8080:8080 ipfs/kubo
DRP_IPFS_API_URL=http://localhost:5001/api/v0
DRP_IPFS_GATEWAY_URL=http://localhost:8080/ipfs/
# Pinning service (optional — leave empty to use local node only)
DRP_IPFS_PINNING_SERVICE_URL=
DRP_IPFS_PINNING_SERVICE_KEY=

# ── Keyring ───────────────────────────────────────────────────────────────────
# Use 'test' for local dev only. Use 'file' or 'os' for anything persistent.
DRP_KEYRING_BACKEND=test

# ── Gas / fees ────────────────────────────────────────────────────────────────
DRP_MIN_GAS_PRICE=0.001udrp
DRP_GAS_ADJUSTMENT=1.5

# ── Off-chain services (AI layer, gateway) ────────────────────────────────────
# These are used by the Python/FastAPI services, not by drpd itself.
DRP_AI_API_KEY=
DRP_GATEWAY_JWT_SECRET=CHANGE_ME_BEFORE_RUNNING

# ── Logging ───────────────────────────────────────────────────────────────────
DRP_LOG_LEVEL=info
