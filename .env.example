# DRP publish-safe environment template
# Copy to .env and replace all *_HERE placeholders with real values.

# Runtime environment
DRP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Blockchain
BLOCKCHAIN_NETWORK=drp-testnet
BLOCKCHAIN_RPC_URL=http://localhost:8545
DRP_RPC_URL=http://localhost:8545

# IPFS / storage
IPFS_API_URL=http://localhost:5001/api/v0
IPFS_GATEWAY_URL=http://localhost:8080/ipfs
ORBITDB_DIR=./orbitdb
DATABASE_NAME=orbitdb-database
DRP_ORBITDB_PEER=/ip4/127.0.0.1/tcp/4001/p2p/YOUR_ORBITDB_PEER_ID_HERE

# Security (required in production)
JWT_SECRET=YOUR_JWT_SECRET_HERE
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE
AI_ENCRYPTION_KEY=YOUR_AI_ENCRYPTION_KEY_HEX_HERE

# Optional external providers
AI_API_KEY=YOUR_API_KEY_HERE

# Monitoring / dashboards
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_ADMIN_PASSWORD_HERE
DRP_NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD_HERE
